<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:padding="12dp"
    android:background="@drawable/bg_card"
    android:elevation="3dp">

    <!-- 🔹 Tên sản phẩm -->
    <TextView
        android:id="@+id/tvTenSP"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tên hàng: Máy khoan DW"
        android:textStyle="bold"
        android:textSize="16sp"
        android:textColor="@color/black"
        android:layout_marginBottom="4dp" />

    <!-- 🔹 Mã sản phẩm -->
    <TextView
        android:id="@+id/tvMaSP"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mã hàng: MS01"
        android:textSize="13sp"
        android:textColor="@color/green_600" />

    <!-- 🔹 Thông tin nhập / xuất / tồn -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:weightSum="3">

        <TextView
            android:id="@+id/tvNhap"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Nhập: +0"
            android:textColor="@color/blue_600"
            android:textStyle="bold"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvXuat"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Xuất: -0"
            android:textColor="@color/purple_500"
            android:textStyle="bold"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvTonKho"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tồn kho: 0 sp"
            android:textColor="@color/green_600"
            android:textStyle="bold"
            android:textSize="14sp"
            android:gravity="end" />
    </LinearLayout>

</LinearLayout>
