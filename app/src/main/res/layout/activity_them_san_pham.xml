<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    tools:context=".ThemSanPhamActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Mã sản phẩm -->
        <TextView
            android:text="Mã sản phẩm (bắt buộc)"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <EditText
            android:id="@+id/edtMaSP"
            android:hint="Nhập mã sản phẩm"
            android:background="@drawable/bg_input"
            android:padding="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Tên sản phẩm -->
        <TextView
            android:text="Tên sản phẩm (bắt buộc)"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:layout_marginTop="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <EditText
            android:id="@+id/edtTenSP"
            android:hint="Nhập tên sản phẩm"
            android:background="@drawable/bg_input"
            android:padding="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Phân loại sản phẩm (AI + thủ công) -->
        <TextView
            android:text="Phân loại sản phẩm"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:layout_marginTop="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <EditText
            android:id="@+id/edtPhanLoai"
            android:hint="AI gợi ý..."
            android:enabled="false"
            android:background="@drawable/bg_input"
            android:padding="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Giá nhập -->
        <TextView
            android:text="Giá nhập"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:layout_marginTop="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <EditText
            android:id="@+id/edtGiaVon"
            android:hint="Nhập giá nhập"
            android:inputType="numberDecimal"
            android:background="@drawable/bg_input"
            android:padding="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Ghi chú -->
        <TextView
            android:text="Ghi chú"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:layout_marginTop="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <EditText
            android:id="@+id/edtGhiChu"
            android:hint="Nhập ghi chú sản phẩm"
            android:background="@drawable/bg_input"
            android:minHeight="80dp"
            android:gravity="top"
            android:padding="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Nút Lưu -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="20dp">

            <Button
                android:id="@+id/btnLuu"
                android:text="Lưu"
                android:backgroundTint="@color/blue_400"
                android:textColor="@android:color/white"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnLuuTaoMoi"
                android:text="Lưu và Tạo mới"
                android:backgroundTint="@color/blue_700"
                android:textColor="@android:color/white"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
